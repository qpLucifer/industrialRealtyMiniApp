# Copy to .env (dev) — production uses .env.production at build time
VITE_USE_MOCK=false
VITE_API_BASE=https://your-api-domain.example.com
# Same host as server OSS_PUBLIC_BASE_URL — required for <video> / previewMedia on OSS files
VITE_OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# DevTools only: manual 11-digit phone login when WeChat phone API unavailable
VITE_MINI_LOGIN_PHONE_FALLBACK=false

# WeChat mini program admin (mp.weixin.qq.com) — add both domains:
# - request 合法域名: VITE_API_BASE host
# - downloadFile 合法域名: VITE_API_BASE host + VITE_OSS_PUBLIC_BASE_URL host

# Must match src/manifest.json → mp-weixin.appid and server WECHAT_MINI_APP_ID
# VITE_MP_WEIXIN_APPID=wx802c623c5215ec70

# Subscribe message: 工作任务接受提醒 (same id on server WECHAT_SUBSCRIBE_TEMPLATE_WORK_TASK)
# VITE_WX_SUBSCRIBE_TEMPLATE_WORK_TASK=o-xUPUgSNctCXEpf1bMudPZtk40NieJgN0x8e-PJLtM

# DevTools: enable manual phone login when getPhoneNumber is unavailable (do not use in production)
# VITE_MINI_LOGIN_PHONE_FALLBACK=true
