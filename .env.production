# Production / experience build for WeChat mini program (uni build -p mp-weixin).
# Must hit real API — otherwise login may hit mock while other paths hit network, or all mock, etc.
VITE_USE_MOCK=false
# Same host as admin static site + Nginx /api proxy (no trailing slash).
VITE_API_BASE=https://jiayizhou.top
# Must match server OSS_PUBLIC_BASE_URL (downloadFile legal domain in WeChat admin)
VITE_OSS_PUBLIC_BASE_URL=
VITE_MINI_LOGIN_PHONE_FALLBACK=false
